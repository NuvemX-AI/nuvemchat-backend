// prisma/schema.prisma
//
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────── Seus modelos existentes ───────────
model User {
  id           Int       @id @default(autoincrement())
  name         String?
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  lastLogin    DateTime  @default(now())
  messages     Message[]
}

// Mensagens genéricas (exemplo antigo)
model Message {
  id                   Int       @id @default(autoincrement())
  tenantId             String
  channel              String
  message              String
  timestamp            DateTime  @default(now())
  sender               String
  senderUsername       String?
  senderProfilePicture String?
  // Relação com WhatsappConversation se desejar
}

// ─────────── Modelo para integrações WhatsApp ───────────
model WhatsappIntegration {
  id          Int       @id @default(autoincrement())
  userId      Int
  instanceId  String    @unique
  sessionData Json?
  status      String    @default("pending")  // pending, connected, error
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─────────── Modelos para Chat ― Contact, Message, MessageUpdate ───────────
model Contact {
  id          Int       @id @default(autoincrement())
  name        String
  phoneNumber String?   // telefone, se aplicável
  // Relação com mensagens
  messages    ChatMessage[]
}

model ChatMessage {
  id          Int       @id @default(autoincrement())
  contactId   Int
  content     String
  sentAt      DateTime  @default(now())
  // Relação inversa
  contact     Contact   @relation(fields: [contactId], references: [id])
}

model MessageUpdate {
  id          Int       @id @default(autoincrement())
  messageId   Int
  updatedAt   DateTime  @updatedAt
  newContent  String
  message     ChatMessage @relation(fields: [messageId], references: [id])
}
