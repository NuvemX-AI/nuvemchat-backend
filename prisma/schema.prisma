// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────── Seus modelos existentes ───────────
model User {
  id           Int       @id @default(autoincrement())
  name         String?
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  lastLogin    DateTime  @default(now())
}

// ─────────── Modelo para integrações WhatsApp ───────────
model WhatsappIntegration {
  id          Int       @id @default(autoincrement())
  userId      Int
  instanceId  String    @unique
  sessionData Json?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ─────────── Modelos para Chat: Contact, Message, MessageUpdate ───────────
model Contact {
  id          Int       @id @default(autoincrement())
  name        String
  phoneNumber String?   
  messages    Message[] // relação inversa com Message
}

model Message {
  id          Int             @id @default(autoincrement())
  contactId   Int
  content     String
  sentAt      DateTime        @default(now())
  contact     Contact         @relation(fields: [contactId], references: [id])
  updates     MessageUpdate[] // relação inversa com MessageUpdate
}

model MessageUpdate {
  id          Int       @id @default(autoincrement())
  messageId   Int
  updatedAt   DateTime  @updatedAt
  newContent  String
  message     Message   @relation(fields: [messageId], references: [id])
}
